---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const productions = [
	{ title: 'Søster', director: 'Søren Lundvall', roles: 'DIT, C-foto, klippeassistent' },
	{ title: 'Eftertid', director: 'Hannah Elbke', roles: 'Klippeassistent' },
	{ title: 'Untitled', director: 'Marie Suul Brobakke', roles: 'Offline/online workflow og data recovery' },
	{ title: 'AMFI', director: 'Mathias Broe', roles: 'C-foto, DIT, klippeassistent' },
	{ title: 'En Rapport om Festen og Gæsterne', director: 'Søren Peter Langkjær Bojsen', roles: 'DIT, klippeassistent, online' },
	{ title: 'UFFE', director: 'J. Sivert Lendorph Christensen', roles: 'C-foto, DIT' },
	{ title: 'Benal på Roskilde', director: 'Andrea Stief', roles: 'Colorgrader' },
	{ title: 'Simon Littauer Musikvideo', director: 'Ian Isak', roles: 'C-foto, DIT' },
	{ title: 'Katrine Brocks afgangsfilm', director: 'Katrine Brocks', roles: 'Klippeassistent' },
	{ title: 'Viktor På Månen', director: 'Christian Arhoff', roles: 'DIT, klippeassistent' },
	{ title: 'Into The Deep', director: 'Emma Sullivan', roles: 'Klippeassistent' },
	{ title: 'Twice Colonized', director: 'Lin Alluna', roles: 'Klippeassistent' },
	{ title: 'En Flirt', director: 'Zinnini Elkington', roles: 'Klippeassistent' },
	{ title: 'Mira', director: 'Ejner Bendict Seidelin', roles: 'Klippeassistent, DIT' },
	{ title: 'HUNGUD', director: 'Sara Hjort', roles: 'B-foto, klippeassistent' },
	{ title: 'Balenciaga Spring 22', director: 'Yilmas Zen', roles: 'C-foto, DIT' },
	{ title: 'Det Store Glitch / Paradisets børn', director: 'Søren Peter Langkjær Bojsen', roles: 'Kortvarig Instruktørassistent, skuespiller' },
	{ title: 'I Am Everything', director: 'Jeppe Lange', roles: 'AI-kunstner, VFX, klippeassistent' },
];

const displayedProductions = [...productions].reverse();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<header class="page-header">
				<h1>Hej, jeg hedder Emil From</h1>
			</header>

			<section class="intro">
				<p>
					Jeg kalder mig selv for kreativ filmtekniker, da jeg laver film ved hjælp af kunstig intelligens, programmering, maskinlæring og alt muligt teknik.
				</p>
				<p>
				Jeg læser Visuel Design og Interaktion på KADK (2026-2029) og har tidligere læst psykologi på KU.
				</p>
				<p>
					Her er mit CV med udvalgte produktioner.
				</p>
			</section>

			<section class="cv-list" aria-label="Produktioner">
				{
					displayedProductions.map((production, index) => (
						<article class="cv-item">
							<span class="cv-index">{String(displayedProductions.length - index).padStart(2, '0')}.</span>
							<span class="cv-dots" aria-hidden="true"></span>
							<div class="cv-content">
								<h2>{production.title}</h2>
								<p><strong>Instruktør:</strong> {production.director}</p>
								<p><strong>Min rolle:</strong> {production.roles}</p>
							</div>
						</article>
					))
				}
			</section>

			<section class="contact" aria-label="Kontakt">
				<a href="mailto:hello@emil.example">Send mig en email på emil [snabel-a] emilfrom.com</a>
			</section>
		</main>
	</body>
</html>
