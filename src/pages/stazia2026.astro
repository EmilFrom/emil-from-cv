<!doctype html>
<html lang="da">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Stazia2026</title>
		<style>
			:root {
				color-scheme: light;
			}
			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				background: #fff7cc;
				font-family: 'Comic Sans MS', 'Comic Sans', cursive;
			}
			main {
				display: grid;
				gap: 1rem;
				justify-items: center;
				text-align: center;
				padding: 1.5rem;
			}
			h1 {
				margin: 0;
				font-size: clamp(2rem, 7vw, 4rem);
				color: #ff2a6d;
			}
			audio {
				width: min(92vw, 360px);
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Tillykke Stazia</h1>
			<audio controls preload="none">
				<source src="/stazia2026.m4a" type="audio/mp4" />
				<source src="/stazia2026.mp3" type="audio/mpeg" />
			</audio>
		</main>
	</body>
</html>
